# Supabase Configuration (Required)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin Secret for creating admin accounts (Required - keep this secure!)
# Generate a strong random string for production
VITE_ADMIN_SECRET=your_secure_random_admin_secret_here

# Optional: Supabase Project ID (for MCP integration)
# VITE_SUPABASE_PROJECT_ID=your_project_id

# Optional: Google OAuth (if using Google authentication)
# GOOGLE_CLIENT_ID=your_google_oauth_client_id
# GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Optional: App URL (for production links)
# VITE_APP_URL=https://your-app-domain.com
